# Backend Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit the actual .env file - use .env.example as template

# ===== SERVER CONFIG =====
PORT=5000
NODE_ENV=development

# ===== AUTHENTICATION =====
# ✅ CRITICAL: Generate a strong random string for JWT secret
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this SECRET and NEVER commit to version control
JWT_SECRET=change-this-to-a-random-string-in-production

# ===== DATABASE =====
# For local development:
#   MONGO_URI=mongodb://localhost:27017/learnCode
# For MongoDB Atlas (recommended for production):
#   MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/learnCode?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/learnCode

# ===== FRONTEND URL (for CORS and email links) =====
# For local development: http://localhost:3000
# For production: https://your-domain.com
CLIENT_URL=http://localhost:3000

# ===== GOOGLE OAUTH =====
# Get from Google Cloud Console: https://console.cloud.google.com/
# Create different OAuth 2.0 Web Application credentials for development and production
GOOGLE_CLIENT_ID=your_google_client_id_here

# ===== EMAIL SERVICE (Optional - for password reset, notifications) =====
# Recommended: Gmail, SendGrid, AWS SES, or similar
# For Gmail with App Password:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an "App Password" for Mail
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# For SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key

# For production, use real email service
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# ===== JWT SECRET (If implementing JWT auth - optional) =====
# JWT_SECRET=your-random-secret-key-min-32-chars-long

# ===== LOGGING =====
# LOG_LEVEL=info
# LOG_FILE=logs/app.log

# ===== API SECURITY =====
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS allowed origins (comma separated for multiple)
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
